# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL — REQUIRED, no fallback ───────────────────────
# On Render: linked automatically when you click
#   Web Service -> Environment -> "Add from database"
# For local dev: copy the "External Database URL" from your
#   Render Postgres dashboard (or any Postgres connection string)
# The server will REFUSE TO START if this is missing or unreachable.
DATABASE_URL=

# ── Admin ───────────────────────────────────────────────────
# Make up any strong password — used to access /api/admin/* routes
ADMIN_SECRET=change_this_to_a_strong_secret

# ── CORS ────────────────────────────────────────────────────
# Your Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app
